  "stages": {
    "learn": {
      "conceptExplanation": {
        "en": "OF3 teaches how to say that a person belongs to, works in, works for, or comes from a ministry, administrative unit, professional association, social group, committee, club, or organization.",
        "fr": "L’OF3 enseigne comment exprimer l’appartenance à un ministère, à une unité administrative, à une association professionnelle ou sociale, à un comité, à un club ou à un organisme."
      },
      "vocabularyNote": "Les indicateurs principaux sont : travailler à, travailler dans, travailler pour, être à, être de, venir de, être membre de, faire partie de et appartenir à. Portez attention aux articles contractés : au, aux, du, des.",
      "grammarNotes": {
        "summary": "Cet objectif combine les indicateurs d’appartenance, les articles définis contractés et les verbes faire et venir au présent.",
        "charts": [],
        "points": [
          "À + le devient au; à + les devient aux. De + le devient du; de + les devient des.",
          "On utilise travailler à ou être à pour une unité ou un service : Je travaille à la Direction des langues officielles.",
          "On utilise travailler pour pour l’employeur ou la personne responsable : Je travaille pour madame Roy.",
          "Être membre de, faire partie de et appartenir à servent à parler d’un groupe, d’une association ou d’un comité.",
          "Venir de et être de indiquent l’origine administrative : Elle vient du Service des finances; il est du Conseil du Trésor.",
          "Faire au présent : je fais, tu fais, il/elle/on fait, nous faisons, vous faites, ils/elles font.",
          "Venir au présent : je viens, tu viens, il/elle/on vient, nous venons, vous venez, ils/elles viennent."
        ]
      },
      "pronunciation": {
        "points": [
          "Écoutez la différence entre au, aux, du et des : ces petits mots portent souvent l’information grammaticale.",
          "Devant une voyelle, de devient d’ : faire partie d’une association, être membre d’un comité."
        ]
      },
      "dialogues": [
        {
          "title": "Demander l’appartenance",
          "lines": [
            {
              "speaker": "A",
              "fr": "Où travaillez-vous?",
              "en": "Where do you work?"
            },
            {
              "speaker": "B",
              "fr": "Je travaille au ministère de la Santé.",
              "en": "I work at the Department of Health."
            },
            {
              "speaker": "A",
              "fr": "De quelle division êtes-vous?",
              "en": "Which division are you from?"
            },
            {
              "speaker": "B",
              "fr": "Je suis de la Division des finances.",
              "en": "I am from the Finance Division."
            }
          ]
        },
        {
          "title": "Indiquer une association",
          "lines": [
            {
              "speaker": "A",
              "fr": "Faites-vous partie d’une association professionnelle?",
              "en": "Are you part of a professional association?"
            },
            {
              "speaker": "B",
              "fr": "Oui, je suis membre de l’Association des cadres de direction.",
              "en": "Yes, I am a member of the Executive Group Association."
            }
          ]
        }
      ],
