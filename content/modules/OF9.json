    "learn": {
      "conceptExplanation": {
        "en": "OF9 teaches how to place events in past, present, and future using time indicators and verb tenses: passé composé, imparfait, présent, futur proche, and futur simple.",
        "fr": "L’OF9 enseigne comment situer des événements au passé, au présent et au futur à l’aide d’indicateurs temporels et des temps verbaux : passé composé, imparfait, présent, futur proche et futur simple."
      },
      "vocabularyNote": "Les indicateurs essentiels sont : hier, avant-hier, il y a, l’année dernière, autrefois, aujourd’hui, ce matin, maintenant, actuellement, présentement, demain, après-demain, bientôt, dans cinq jours, la semaine prochaine.",
      "grammarNotes": {
        "summary": "Cet objectif combine les indicateurs temporels avec les temps verbaux qui marquent le passé, le présent et le futur.",
        "charts": [],
        "points": [
          "Passé composé : action terminée dans le passé, souvent avec hier, le mois dernier ou il y a.",
          "Imparfait : situation ou habitude passée, souvent avec autrefois ou l’année dernière.",
          "Présent : situation actuelle, habitude ou action en cours, avec maintenant, aujourd’hui, actuellement.",
          "Futur proche : aller + infinitif, souvent pour un futur planifié ou proche.",
          "Futur simple : forme en -rai/-ras/-ra/-rons/-rez/-ront, souvent avec demain, bientôt, dans cinq jours.",
          "Être en train de + infinitif insiste sur une action en cours : Je suis en train d’écouter.",
          "Depuis + durée avec le présent indique une action commencée dans le passé et encore vraie maintenant."
        ]
      },
      "pronunciation": {
        "points": [
          "Écoutez les marqueurs courts comme hier, demain, dans et il y a; ils changent complètement la référence temporelle.",
          "Le futur simple et l’imparfait ont souvent des finales proches à l’oral; fiez-vous aussi aux indicateurs de temps."
        ]
      },
      "dialogues": [
        {
          "title": "Passé, Présent, Futur",
          "lines": [
            {
              "speaker": "A",
              "fr": "Hier, j’ai lavé ma voiture.",
