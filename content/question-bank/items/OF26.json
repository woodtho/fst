      ],
      "explanation": {
        "correct_why": "« je cherche [le dossier] » — the dossier is the direct object of cherche, so the relative pronoun is « que ».",
        "distractor_why": {
          "subject": "« qui » is used when the relative is the subject (le dossier qui est sur le bureau).",
          "de_relative": "« dont » replaces de + noun (le dossier dont j’ai besoin)."
        },
        "grammar_rule": "qui = subject of the relative clause; que = direct object.",
        "vocab_notes": "chercher = to look for (no preposition).",
        "common_mistakes": [
          "confusing qui (subject) and que (object)"
        ]
      },
      "tip": {
        "memory_aid": "que + subject+verb; qui + verb directly.",
        "pattern": "If a subject follows, use que; if a verb follows, use qui.",
        "similar": [
          "le rapport que j’ai écrit",
          "le collègue qui travaille ici"
        ]
      }
