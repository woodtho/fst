              "speaker": "A",
              "fr": "Excusez-moi. Je cherche le bureau de madame Sauvé.",
              "en": "Excuse me. I’m looking for Ms. Sauvé’s office."
            },
            {
              "speaker": "B",
              "fr": "Allez jusqu’au bout du corridor.",
              "en": "Go to the end of the hallway."
            }
          ]
        }
