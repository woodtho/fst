      "conceptExplanation": {
        "en": "OF7 teaches how to ask for directions, give route instructions, understand movement directions, and verify information while orienting someone in space.",
        "fr": "L’OF7 enseigne comment demander un trajet, donner des directives, comprendre des indications de déplacement et vérifier l’information lorsqu’on oriente quelqu’un dans l’espace."
      },
      "vocabularyNote": "Les mots clés sont monter, descendre, entrer, sortir, tourner, traverser, continuer, suivre, passer, prendre, aller jusqu’à, passer par, à droite, à gauche, tout droit et au bout.",
      "grammarNotes": {
        "summary": "Cet objectif combine les verbes aller/venir, les verbes de déplacement, l’impératif, les prépositions de trajet, les pronoms y/en et les questions comment, par où et par quel chemin.",
        "charts": [],
        "points": [
          "Aller au présent : je vais, tu vas, il/elle/on va, nous allons, vous allez, ils/elles vont.",
          "Venir au présent : je viens, tu viens, il/elle/on vient, nous venons, vous venez, ils/elles viennent.",
          "L’impératif sert à donner une directive : Tournez à droite; Prenez l’ascenseur; Continue tout droit.",
          "Y remplace une destination introduite par à : Je vais au bureau -> J’y vais.",
          "En remplace une origine introduite par de : Je sors du bureau -> J’en sors.",
          "Les prépositions de trajet incluent jusqu’à, par, devant, dans, vers, de et à.",
          "Pour demander un trajet : Comment est-ce qu’on va...? Par où passe-t-on...? Par quel chemin...?"
        ]
      },
      "pronunciation": {
        "points": [
          "Dans les directives, écoutez les groupes de souffle : Prenez la rue Nicholas, puis le Queensway, vers l’est.",
          "Les enchaînements autour de y et en sont courts et rapides : j’y vais, j’en sors."
        ]
      },
      "dialogues": [
        {
          "title": "Demander son chemin",
          "lines": [
            {
              "speaker": "A",
              "fr": "Pardon, comment est-ce qu’on va à la gare?",
              "en": "Excuse me, how do we get to the train station?"
            },
            {
              "speaker": "B",
              "fr": "Prenez la rue Nicholas, puis le Queensway, vers l’est. C’est à droite.",
              "en": "Take Nicholas Street, then the Queensway east. It is on the right."
            }
          ]
        },
        {
          "title": "Dans un édifice",
          "lines": [
