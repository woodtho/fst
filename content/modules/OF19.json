  "stages": {
    "learn": {
      "conceptExplanation": {
        "en": "OF19 teaches how to evaluate things: describe physical qualities, compare two or more things, use superlatives, ask for descriptions, give opinions, and understand weather or quality assessments.",
        "fr": "OF19 enseigne comment évaluer des choses : décrire des qualités physiques, comparer deux ou plusieurs choses, employer les superlatifs, demander une description, donner une opinion et comprendre des évaluations de météo ou de qualité."
      },
      "vocabularyNote": "Vocabulaire central : couleur, dimension, forme, état, matière, éclairé, bruyant, lisible, insonorisé, acceptable, adéquat, efficace, satisfaisant, conforme, semblable, différent, supérieur, inférieur, selon moi, à mon avis, je trouve que.",
      "grammarNotes": {
        "summary": "OF19 focuses on adjective agreement, descriptive complements, comparatives, superlatives and opinion indicators followed by the indicative.",
        "charts": [],
        "points": [
          "Describe a thing by colour, size, shape, condition and material: un classeur bleu, un bureau rectangulaire, une lampe en métal.",
          "Many adjective endings change with gender and number: bruyant/bruyante, institutionnel/institutionnelle, personnel/personnelle.",
          "Compare quality with plus/aussi/moins + adjective/adverb + que: plus pratique que, aussi utile que, moins bien que.",
          "Compare quantity with plus de, autant de and moins de: plus de dossiers que de formulaires.",
          "Use meilleur, mieux, pire and moins bon for common irregular comparisons.",
          "Use superlatives with le/la/les plus or le/la/les moins: le plus urgent, la moins efficace.",
          "Ask for description with Comment est...? À quoi ressemble...? Pourriez-vous me le décrire?",
          "Opinion indicators include selon moi, d'après vous, à mon avis, je pense que, je crois que, je trouve que, il me semble que."
        ]
      },
      "pronunciation": {
        "points": [
          "OF19 includes syllable-count practice; pronounce groups such as très, une heure and avenue des Pins as rhythmic chunks.",
          "Practice oral/final vowel contrasts in short words such as sec, vite and par."
        ]
      },
      "dialogues": [
        {
          "title": "Décrire Un Objet",
          "lines": [
            {
              "speaker": "A",
              "text": "Pourriez-vous me décrire l'objet perdu?"
            },
            {
              "speaker": "B",
              "text": "C'est un sac à main en cuir brun avec bandoulière."
            },
            {
              "speaker": "A",
              "text": "Dans quel état est-il?"
            },
            {
              "speaker": "B",
              "text": "Il est en bon état."
            }
          ]
        },
        {
          "title": "Donner Une Opinion",
          "lines": [
            {
              "speaker": "A",
              "text": "Que penses-tu de l'exercice de feu?"
            },
            {
              "speaker": "B",
              "text": "Je trouve que c'est une bonne idée."
            },
            {
              "speaker": "A",
              "text": "À ton avis, la bibliothèque répond-elle aux besoins?"
            },
            {
              "speaker": "B",
              "text": "Selon moi, vous donnez un excellent service."
            }
          ]
        }
      ],
