  "rules": [
    {
      "id": "aux_choice",
      "fr": "La plupart des verbes utilisent avoir. Les verbes de mouvement/changement d'état (DR & MRS VANDERTRAMP) et tous les verbes pronominaux utilisent être.",
      "en": "Most verbs use avoir. Movement/state-change verbs and all pronominal verbs use être."
    },
    {
      "id": "etre_agreement",
      "fr": "Avec être, le participe s'accorde avec le sujet en genre et en nombre.",
      "en": "With être, the participle agrees with the subject in gender and number."
    },
    {
      "id": "avoir_agreement",
      "fr": "Avec avoir, le participe s'accorde seulement avec l'objet direct s'il est placé AVANT le verbe.",
      "en": "With avoir, the participle agrees only with a direct object that PRECEDES the verb."
    }
  ],
