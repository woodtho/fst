  "stages": {
    "learn": {
      "conceptExplanation": {
        "en": "OF6 teaches how to understand and give numerical information: quantities, prices, ages, addresses, telephone numbers, social insurance numbers, salaries, ranks, and approximate amounts.",
        "fr": "L’OF6 enseigne comment comprendre et fournir des données chiffrées : quantités, prix, âges, adresses, numéros de téléphone, numéros d’assurance sociale, salaires, rangs et quantités approximatives."
      },
      "vocabularyNote": "Les données chiffrées les plus fréquentes dans cet objectif sont les prix, les numéros de téléphone, les adresses, les numéros de pièce, les quantités d’articles, les âges et les salaires.",
      "grammarNotes": {
        "summary": "Cet objectif porte sur les nombres cardinaux, collectifs et ordinaux, ainsi que sur combien et les démonstratifs.",
        "charts": [],
        "points": [
          "Les nombres cardinaux indiquent une quantité exacte : 25 $, 300 exemplaires, 564-7871.",
          "Les nombres ordinaux indiquent le rang : premier/première, deuxième, troisième, 18e étage.",
          "Les collectifs indiquent une quantité approximative : une dizaine, une douzaine, une vingtaine, une centaine, un millier.",
          "Combien sert à demander une quantité ou un prix : Combien ça coûte? Combien d’exemplaires?",
          "Avec une préposition, on dit de combien de, avec combien de, pour combien de, à combien de, dans combien de.",
          "Les démonstratifs ce/cet/cette/ces accompagnent un nom; celui-ci/celle-là/ceux-ci remplacent un nom.",
          "Les montants en français utilisent souvent la virgule décimale : 27,50 $, 565,75 $."
        ]
      },
      "pronunciation": {
        "points": [
          "Pour les numéros de téléphone, écoutez les groupes de chiffres et les répétitions : 614-9145, 6...1...4... 9...1...4...5.",
          "Les grands nombres doivent être segmentés mentalement : 1 300 000, 7 000 647."
        ]
      },
      "dialogues": [
        {
          "title": "Demander un prix",
          "lines": [
            {
              "speaker": "A",
              "fr": "Vous demandez combien pour cette radio?",
              "en": "How much are you asking for this radio?"
            },
            {
              "speaker": "B",
              "fr": "Soixante-cinq dollars.",
              "en": "Sixty-five dollars."
            },
            {
              "speaker": "A",
              "fr": "Quel est votre numéro de téléphone?",
              "en": "What is your phone number?"
            },
            {
              "speaker": "B",
              "fr": "C’est le 568-7437.",
              "en": "It is 568-7437."
            }
          ]
        },
        {
          "title": "Commander des fournitures",
          "lines": [
            {
              "speaker": "A",
