  "stages": {
    "learn": {
      "conceptExplanation": {
        "en": "OF4 teaches how to express possession and ownership, identify the owner of an object or document, and describe objects by colour, shape, size, material, and condition.",
        "fr": "L’OF4 enseigne comment exprimer la possession, identifier le possesseur d’un objet ou d’un document et décrire un objet par sa couleur, sa forme, sa dimension, sa matière et son état."
      },
      "vocabularyNote": "Les formes centrales sont avoir, posséder, être propriétaire de, être à, appartenir à, de/du/des, les adjectifs possessifs et les pronoms possessifs. Pour les descriptions, retenez les catégories couleur, forme, dimension, matière et état.",
      "grammarNotes": {
        "summary": "Cet objectif combine le verbe avoir, les adjectifs possessifs, les pronoms possessifs et l’accord/place des adjectifs.",
        "charts": [],
        "points": [
          "Avoir au présent : j’ai, tu as, il/elle/on a, nous avons, vous avez, ils/elles ont.",
          "L’adjectif possessif s’accorde avec l’objet possédé : mon bureau, ma serviette, mes dossiers.",
          "Devant une voyelle féminine, on emploie mon/ton/son : mon auto, ton idée, son agrafeuse.",
          "Le pronom possessif remplace le nom : mon bureau devient le mien; ma copie devient la mienne.",
          "Être à + pronom indique le possesseur : Le livre est à moi; les dossiers sont à vous.",
          "De/du/des indique aussi le possesseur : le bureau du chef, les copies des coordonnateurs.",
          "Les adjectifs de couleur, forme, dimension et état s’accordent généralement avec le nom décrit."
        ]
      },
      "pronunciation": {
        "points": [
          "Travaillez la syllabation avec des mots comme en/tre/po/sage, or/di/na/teur et in/ter/gou/ver/ne/men/tal.",
          "Écoutez l’enchaînement et la liaison dans des suites comme Vous avez de beaux enfants et On arrive au dernier étage."
        ]
      },
      "dialogues": [
        {
          "title": "Identifier le possesseur",
          "lines": [
            {
              "speaker": "A",
              "fr": "C’est à qui, ce dossier-là?",
              "en": "Whose file is this?"
            },
            {
              "speaker": "B",
              "fr": "C’est à Micheline.",
              "en": "It belongs to Micheline."
            },
            {
              "speaker": "A",
              "fr": "Et ces copies?",
              "en": "And these copies?"
            },
            {
              "speaker": "B",
              "fr": "Ce sont les siennes.",
              "en": "They are hers."
            }
          ]
        },
        {
          "title": "Décrire un objet",
          "lines": [
            {
              "speaker": "A",
              "fr": "C’est ton classeur?",
              "en": "Is that your filing cabinet?"
            },
            {
              "speaker": "B",
              "fr": "Non, le mien est gris et rectangulaire.",
              "en": "No, mine is grey and rectangular."
            }
          ]
        }
      ],
