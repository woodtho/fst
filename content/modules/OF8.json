  "stages": {
    "learn": {
      "conceptExplanation": {
        "en": "OF8 teaches how to locate events in time: clock times, dates, days, months, seasons, years, deadlines, appointments, reservations, confirmations, and cancellations.",
        "fr": "L’OF8 enseigne comment situer un événement dans le temps : heures, dates, jours, mois, saisons, années, échéances, rendez-vous, réservations, confirmations et annulations."
      },
      "vocabularyNote": "Les repères de temps principaux sont : aujourd’hui, demain, hier, le matin, l’après-midi, le soir, la nuit, lundi à dimanche, janvier à décembre, printemps, été, automne, hiver, à midi, à minuit, à 10 h 30, le 1er janvier et en 2004.",
      "grammarNotes": {
        "summary": "Cet objectif combine les prépositions de temps, les questions temporelles et les verbes en -ir au présent.",
        "charts": [],
        "points": [
          "On emploie à pour une heure : à 10 h 30, à midi, à minuit.",
          "On emploie le pour une date précise : le 1er juillet, le 25 décembre.",
          "On emploie en pour une année, un mois ou une saison : en 2004, en février, en automne.",
          "Pour demander l’heure : À quelle heure...? Pour demander la date : À quelle date...? Pour demander l’année : En quelle année...?",
          "Quand est plus général et peut remplacer plusieurs questions temporelles.",
          "Les verbes réguliers en -ir comme finir : je finis, tu finis, il finit, nous finissons, vous finissez, ils finissent.",
          "Pour les arrangements, distinguez prendre rendez-vous, confirmer, annuler, remettre et réserver."
        ]
      },
      "pronunciation": {
        "points": [
          "Les heures se groupent souvent en blocs : 13 h 25 min 10 s; 10 h 30; 17 h 15.",
          "Écoutez la liaison dans les expressions comme à onze heures et à huit heures."
        ]
      },
      "dialogues": [
        {
          "title": "Prendre Rendez-Vous",
          "lines": [
            {
              "speaker": "A",
              "fr": "J’aimerais prendre rendez-vous jeudi.",
              "en": "I would like to make an appointment on Thursday."
            },
            {
              "speaker": "B",
              "fr": "Jeudi à 17 h. Ça vous convient?",
              "en": "Thursday at 5 p.m. Does that work for you?"
            },
            {
              "speaker": "A",
              "fr": "Oui, très bien.",
              "en": "Yes, very well."
            }
          ]
        },
        {
          "title": "Confirmer Une Réservation",
          "lines": [
            {
              "speaker": "A",
              "fr": "J’appelle pour confirmer les réservations d’avion.",
              "en": "I’m calling to confirm the flight reservations."
            },
            {
              "speaker": "B",
              "fr": "Très bien. Le départ est jeudi 3 mars à 20 h 50.",
              "en": "Very well. Departure is Thursday, March 3 at 8:50 p.m."
            }
          ]
        }
      ],
